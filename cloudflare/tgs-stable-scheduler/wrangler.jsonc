{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tgs-stable-scheduler",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "workers_dev": false,
  "triggers": {
    "crons": [
      "37 7 * * MON-FRI"
    ]
  },
  "secrets": {
    "required": ["GITHUB_ACTIONS_TOKEN"]
  }
}
